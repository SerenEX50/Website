<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bank Login & Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        primary: '#1e40af',
                        secondary: '#3b82f6',
                        accent: '#f59e0b',
                        dark: '#0f172a'
                    }
                }
            }
        }
    </script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap');
        body {
            font-family: 'Poppins', sans-serif;
            background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
            min-height: 100vh;
        }
        .card-hover {
            transition: all 0.3s ease;
        }
        .card-hover:hover {
            transform: translateY(-5px);
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
        }
        .fade-in {
            animation: fadeIn 0.5s ease-in;
        }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        .balance-animation {
            animation: balancePulse 2s infinite;
        }
        @keyframes balancePulse {
            0% { transform: scale(1); }
            50% { transform: scale(1.02); }
            100% { transform: scale(1); }
        }
    </style>
</head>
<body class="min-h-screen flex items-center justify-center p-4">
    <!-- Login Screen -->
    <div id="loginScreen" class="w-full max-w-md">
        <div class="bg-white rounded-2xl shadow-xl p-8 fade-in">
            <div class="text-center mb-8">
                <div class="mx-auto bg-primary w-16 h-16 rounded-full flex items-center justify-center mb-4">
                    <i class="fas fa-university text-white text-2xl"></i>
                </div>
                <h1 class="text-2xl font-bold text-gray-800">Welcome Back</h1>
                <p class="text-gray-600 mt-2">Sign in to access your account</p>
            </div>

            <form id="loginForm" class="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Account Number</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-user text-gray-400"></i>
                        </div>
                        <input type="text" id="accountNumber" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Enter your account number" required>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Password</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-lock text-gray-400"></i>
                        </div>
                        <input type="password" id="password" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Enter your password" required>
                    </div>
                </div>

                <div class="flex items-center justify-between">
                    <div class="flex items-center">
                        <input id="remember" type="checkbox" class="h-4 w-4 text-primary focus:ring-primary border-gray-300 rounded">
                        <label for="remember" class="ml-2 block text-sm text-gray-700">Remember me</label>
                    </div>
                    <button type="button" class="text-sm text-primary hover:text-secondary font-medium">Forgot Password?</button>
                </div>

                <button type="submit" class="w-full bg-primary hover:bg-blue-800 text-white font-semibold py-3 px-4 rounded-lg transition duration-300 transform hover:scale-[1.02]">
                    Sign In
                </button>
            </form>

            <div class="mt-6 text-center">
                <p class="text-gray-600 text-sm">
                    Don't have an account? 
                    <button class="text-primary font-medium hover:text-secondary ml-1">Register now</button>
                </p>
            </div>
        </div>
    </div>

    <!-- Home Screen (Hidden by default) -->
    <div id="homeScreen" class="hidden w-full max-w-6xl">
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden">
            <!-- Header -->
            <div class="bg-primary text-white p-6">
                <div class="flex justify-between items-center">
                    <div>
                        <h1 class="text-xl font-bold">Bank Dashboard</h1>
                        <p class="text-blue-100 text-sm">Good day, Razon,Irish</p>
                    </div>
                    <div class="flex items-center space-x-4">
                        <button class="bg-white bg-opacity-20 hover:bg-opacity-30 p-2 rounded-full transition">
                            <i class="fas fa-bell"></i>
                        </button>
                        <div class="flex items-center space-x-2">
                            <div class="bg-white bg-opacity-20 rounded-full p-1">
                                <i class="fas fa-user text-white"></i>
                            </div>
                            <span class="font-medium">Razon,Irish</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Balance Section -->
            <div class="p-6 border-b">
                <div class="flex justify-between items-center">
                    <div>
                        <p class="text-gray-600 text-sm">Total Balance</p>
                        <h2 class="text-3xl font-bold text-gray-800 balance-animation">₱0.00</h2>
                    </div>
                    <div class="text-right">
                        <p class="text-gray-600 text-sm">Available Funds</p>
                        <p class="text-xl font-semibold text-green-600">₱0.00</p>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="p-6">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Quick Actions</h3>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                    <button id="transferBtn" class="card-hover bg-blue-50 hover:bg-blue-100 p-4 rounded-xl text-center transition">
                        <div class="bg-blue-100 w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-2">
                            <i class="fas fa-exchange-alt text-blue-600 text-xl"></i>
                        </div>
                        <p class="font-medium text-gray-800">Transfer</p>
                    </button>
                    <button id="depositBtn" class="card-hover bg-green-50 hover:bg-green-100 p-4 rounded-xl text-center transition">
                        <div class="bg-green-100 w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-2">
                            <i class="fas fa-money-bill-wave text-green-600 text-xl"></i>
                        </div>
                        <p class="font-medium text-gray-800">Deposit</p>
                    </button>
                    <button id="payBillsBtn" class="card-hover bg-purple-50 hover:bg-purple-100 p-4 rounded-xl text-center transition">
                        <div class="bg-purple-100 w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-2">
                            <i class="fas fa-file-invoice-dollar text-purple-600 text-xl"></i>
                        </div>
                        <p class="font-medium text-gray-800">Pay Bills</p>
                    </button>
                    <button id="historyBtn" class="card-hover bg-orange-50 hover:bg-orange-100 p-4 rounded-xl text-center transition">
                        <div class="bg-orange-100 w-12 h-12 rounded-full flex items-center justify-center mx-auto mb-2">
                            <i class="fas fa-history text-orange-600 text-xl"></i>
                        </div>
                        <p class="font-medium text-gray-800">History</p>
                    </button>
                </div>
            </div>

            <!-- Savings Section -->
            <div class="p-6 border-t">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-lg font-semibold text-gray-800">Savings</h3>
                    <button id="addSavingsBtn" class="bg-primary hover:bg-blue-800 text-white font-semibold py-2 px-4 rounded-lg transition">
                        Add Savings
                    </button>
                </div>
                <div class="bg-gradient-to-r from-blue-50 to-indigo-50 p-6 rounded-xl border border-blue-100">
                    <div class="flex justify-between items-center">
                        <div>
                            <p class="text-gray-600 text-sm">Current Savings</p>
                            <h4 class="text-3xl font-bold text-gray-800">₱0.00</h4>
                        </div>
                        <div class="bg-blue-100 w-16 h-16 rounded-full flex items-center justify-center">
                            <i class="fas fa-piggy-bank text-blue-600 text-2xl"></i>
                        </div>
                    </div>
                    <div class="mt-4">
                        <div class="flex justify-between text-sm text-gray-600 mb-1">
                            <span>Target Goal: ₱5,000.00</span>
                            <span>0%</span>
                        </div>
                        <div class="w-full bg-gray-200 rounded-full h-2.5">
                            <div class="bg-blue-600 h-2.5 rounded-full" style="width: 0%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Recent Transactions -->
            <div class="p-6 border-t">
                <div class="flex justify-between items-center mb-4">
                    <h3 class="text-lg font-semibold text-gray-800">Recent Transactions</h3>
                    <button class="text-primary text-sm font-medium hover:text-secondary">View All</button>
                </div>
                <div class="space-y-3">
                    <div class="flex items-center justify-between p-3 hover:bg-gray-50 rounded-lg transition">
                        <div class="flex items-center space-x-3">
                            <div class="bg-green-100 w-10 h-10 rounded-full flex items-center justify-center">
                                <i class="fas fa-arrow-down text-green-600"></i>
                            </div>
                            <div>
                                <p class="font-medium text-gray-800">Salary Deposit</p>
                                <p class="text-sm text-gray-600">Today, 09:30 AM</p>
                            </div>
                        </div>
                        <p class="font-semibold text-green-600">+₱3,200.00</p>
                    </div>
                    <div class="flex items-center justify-between p-3 hover:bg-gray-50 rounded-lg transition">
                        <div class="flex items-center space-x-3">
                            <div class="bg-red-100 w-10 h-10 rounded-full flex items-center justify-center">
                                <i class="fas fa-arrow-up text-red-600"></i>
                            </div>
                            <div>
                                <p class="font-medium text-gray-800">Grocery Shopping</p>
                                <p class="text-sm text-gray-600">Yesterday, 06:15 PM</p>
                            </div>
                        </div>
                        <p class="font-semibold text-red-600">-₱85.30</p>
                    </div>
                    <div class="flex items-center justify-between p-3 hover:bg-gray-50 rounded-lg transition">
                        <div class="flex items-center space-x-3">
                            <div class="bg-blue-100 w-10 h-10 rounded-full flex items-center justify-center">
                                <i class="fas fa-mobile-alt text-blue-600"></i>
                            </div>
                            <div>
                                <p class="font-medium text-gray-800">Mobile Payment</p>
                                <p class="text-sm text-gray-600">Jun 12, 03:45 PM</p>
                            </div>
                        </div>
                        <p class="font-semibold text-red-600">-₱45.00</p>
                    </div>
                </div>
            </div>

            <!-- Quick Stats Cards -->
            <div class="p-6 border-t">
                <h3 class="text-lg font-semibold text-gray-800 mb-4">Account Overview</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <div class="bg-blue-50 p-4 rounded-xl">
                        <div class="flex justify-between items-center">
                            <div>
                                <p class="text-gray-600 text-sm">Savings Account</p>
                                <h4 class="text-xl font-bold text-gray-800">₱0.00</h4>
                            </div>
                            <div class="bg-blue-100 w-10 h-10 rounded-full flex items-center justify-center">
                                <i class="fas fa-piggy-bank text-blue-600"></i>
                            </div>
                        </div>
                    </div>
                    <div class="bg-green-50 p-4 rounded-xl">
                        <div class="flex justify-between items-center">
                            <div>
                                <p class="text-gray-600 text-sm">Checking Account</p>
                                <h4 class="text-xl font-bold text-gray-800">₱0.00</h4>
                            </div>
                            <div class="bg-green-100 w-10 h-10 rounded-full flex items-center justify-center">
                                <i class="fas fa-wallet text-green-600"></i>
                            </div>
                        </div>
                    </div>
                    <div class="bg-purple-50 p-4 rounded-xl">
                        <div class="flex justify-between items-center">
                            <div>
                                <p class="text-gray-600 text-sm">Credit Card</p>
                                <h4 class="text-xl font-bold text-gray-800">₱0.00</h4>
                            </div>
                            <div class="bg-purple-100 w-10 h-10 rounded-full flex items-center justify-center">
                                <i class="fas fa-credit-card text-purple-600"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Footer -->
            <div class="bg-gray-50 p-4 border-t">
                <div class="flex justify-between items-center">
                    <p class="text-gray-600 text-sm">© 2023 BankSecure. All rights reserved.</p>
                    <div class="flex space-x-4">
                        <button class="text-gray-500 hover:text-primary">
                            <i class="fab fa-facebook-f"></i>
                        </button>
                        <button class="text-gray-500 hover:text-primary">
                            <i class="fab fa-twitter"></i>
                        </button>
                        <button class="text-gray-500 hover:text-primary">
                            <i class="fab fa-instagram"></i>
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Savings Modal -->
    <div id="savingsModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-gray-800">Add to Savings</h3>
                <button id="closeModal" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-2">Amount</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-peso-sign text-gray-400"></i>
                    </div>
                    <input type="number" id="savingsAmount" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Enter amount to add" min="0" step="0.01" required>
                </div>
            </div>
            <div class="flex justify-end space-x-3">
                <button id="cancelSavings" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
                    Cancel
                </button>
                <button id="confirmSavings" class="px-4 py-2 bg-primary hover:bg-blue-800 text-white rounded-lg">
                    Add to Savings
                </button>
            </div>
        </div>
    </div>

    <!-- Deposit Modal -->
    <div id="depositModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-gray-800">Deposit Funds</h3>
                <button id="closeDepositModal" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-2">Amount</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-peso-sign text-gray-400"></i>
                    </div>
                    <input type="number" id="depositAmount" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Enter amount to deposit" min="0" step="0.01" required>
                </div>
            </div>
            <div class="flex justify-end space-x-3">
                <button id="cancelDeposit" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
                    Cancel
                </button>
                <button id="confirmDeposit" class="px-4 py-2 bg-primary hover:bg-blue-800 text-white rounded-lg">
                    Confirm Deposit
                </button>
            </div>
        </div>
    </div>

    <!-- Transfer Modal -->
    <div id="transferModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-gray-800">Transfer Funds</h3>
                <button id="closeTransferModal" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="mb-4">
                <label class="block text-sm font-medium text-gray-700 mb-2">Recipient Account</label>
                <input type="text" id="recipientAccount" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Enter recipient's account number" required>
            </div>
            <div class="mb-6">
                <label class="block text-sm font-medium text-gray-700 mb-2">Amount</label>
                <div class="relative">
                    <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                        <i class="fas fa-peso-sign text-gray-400"></i>
                    </div>
                    <input type="number" id="transferAmount" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Enter amount to transfer" min="0" step="0.01" required>
                </div>
            </div>
            <div class="flex justify-end space-x-3">
                <button id="cancelTransfer" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
                    Cancel
                </button>
                <button id="confirmTransfer" class="px-4 py-2 bg-primary hover:bg-blue-800 text-white rounded-lg">
                    Confirm Transfer
                </button>
            </div>
        </div>
    </div>

    <!-- Pay Bills Modal -->
    <div id="payBillsModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-md p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-gray-800">Pay Bills</h3>
                <button id="closePayBillsModal" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="space-y-4">
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Bill Type</label>
                    <select id="billType" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent">
                        <option value="">Select bill type</option>
                        <option value="electricity">Electricity</option>
                        <option value="water">Water</option>
                        <option value="internet">Internet</option>
                        <option value="phone">Phone</option>
                        <option value="rent">Rent</option>
                        <option value="other">Other</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Account Number</label>
                    <input type="text" id="billAccount" class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Enter account number">
                </div>
                <div>
                    <label class="block text-sm font-medium text-gray-700 mb-2">Amount</label>
                    <div class="relative">
                        <div class="absolute inset-y-0 left-0 pl-3 flex items-center pointer-events-none">
                            <i class="fas fa-peso-sign text-gray-400"></i>
                        </div>
                        <input type="number" id="billAmount" class="pl-10 w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Enter amount" min="0" step="0.01">
                    </div>
                </div>
            </div>
            <div class="mt-6 flex justify-end space-x-3">
                <button id="cancelPayBills" class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
                    Cancel
                </button>
                <button id="confirmPayBills" class="px-4 py-2 bg-primary hover:bg-blue-800 text-white rounded-lg">
                    Pay Bill
                </button>
            </div>
        </div>
    </div>

    <!-- Transaction History Modal -->
    <div id="historyModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center p-4 z-50">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-2xl p-6">
            <div class="flex justify-between items-center mb-4">
                <h3 class="text-xl font-bold text-gray-800">Transaction History</h3>
                <button id="closeHistoryModal" class="text-gray-500 hover:text-gray-700">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-200">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Description</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Amount</th>
                            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                        </tr>
                    </thead>
                    <tbody class="bg-white divide-y divide-gray-200">
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Today, 09:30 AM</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Salary Deposit</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600">+₱3,200.00</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600">Completed</td>
                        </tr>
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Yesterday, 06:15 PM</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Grocery Shopping</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600">-₱85.30</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600">Completed</td>
                        </tr>
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Jun 12, 03:45 PM</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Mobile Payment</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600">-₱45.00</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600">Completed</td>
                        </tr>
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Jun 10, 11:20 AM</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">Online Purchase</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600">-₱120.50</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600">Completed</td>
                        </tr>
                        <tr>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">Jun 8, 02:15 PM</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-gray-900">ATM Withdrawal</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-red-600">-₱200.00</td>
                            <td class="px-6 py-4 whitespace-nowrap text-sm text-green-600">Completed</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="mt-6 flex justify-end">
                <button id="printHistory" class="px-4 py-2 bg-gray-200 hover:bg-gray-300 text-gray-800 rounded-lg">
                    Print History
                </button>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const loginScreen = document.getElementById('loginScreen');
            const homeScreen = document.getElementById('homeScreen');
            const loginForm = document.getElementById('loginForm');
            const addSavingsBtn = document.getElementById('addSavingsBtn');
            const transferBtn = document.getElementById('transferBtn');
            const depositBtn = document.getElementById('depositBtn');
            const payBillsBtn = document.getElementById('payBillsBtn');
            const historyBtn = document.getElementById('historyBtn');
            const savingsModal = document.getElementById('savingsModal');
            const closeModal = document.getElementById('closeModal');
            const cancelSavings = document.getElementById('cancelSavings');
            const confirmSavings = document.getElementById('confirmSavings');
            const savingsAmountInput = document.getElementById('savingsAmount');
            
            // Deposit Modal Elements
            const depositModal = document.getElementById('depositModal');
            const closeDepositModal = document.getElementById('closeDepositModal');
            const cancelDeposit = document.getElementById('cancelDeposit');
            const confirmDeposit = document.getElementById('confirmDeposit');
            const depositAmountInput = document.getElementById('depositAmount');
            
            // Transfer Modal Elements
            const transferModal = document.getElementById('transferModal');
            const closeTransferModal = document.getElementById('closeTransferModal');
            const cancelTransfer = document.getElementById('cancelTransfer');
            const confirmTransfer = document.getElementById('confirmTransfer');
            const recipientAccountInput = document.getElementById('recipientAccount');
            const transferAmountInput = document.getElementById('transferAmount');

            // Pay Bills Modal Elements
            const payBillsModal = document.getElementById('payBillsModal');
            const closePayBillsModal = document.getElementById('closePayBillsModal');
            const cancelPayBills = document.getElementById('cancelPayBills');
            const confirmPayBills = document.getElementById('confirmPayBills');
            const billTypeInput = document.getElementById('billType');
            const billAccountInput = document.getElementById('billAccount');
            const billAmountInput = document.getElementById('billAmount');

            // History Modal Elements
            const historyModal = document.getElementById('historyModal');
            const closeHistoryModal = document.getElementById('closeHistoryModal');
            const printHistoryBtn = document.getElementById('printHistory');

            // Handle login form submission
            loginForm.addEventListener('submit', function(e) {
                e.preventDefault();
                
                const accountNumber = document.getElementById('accountNumber').value;
                const password = document.getElementById('password').value;
                
                // Simple validation
                if(accountNumber && password) {
                    // Hide login screen and show home screen
                    loginScreen.classList.add('hidden');
                    homeScreen.classList.remove('hidden');
                    
                    // Add animation effect
                    homeScreen.classList.add('fade-in');
                } else {
                    alert('Please fill in all fields');
                }
            });

            // Open savings modal
            addSavingsBtn.addEventListener('click', function() {
                savingsModal.classList.remove('hidden');
                savingsAmountInput.value = '';
            });

            // Close modal
            closeModal.addEventListener('click', function() {
                savingsModal.classList.add('hidden');
            });
            
            cancelSavings.addEventListener('click', function() {
                savingsModal.classList.add('hidden');
            });

            // Confirm savings addition
            confirmSavings.addEventListener('click', function() {
                const amount = parseFloat(savingsAmountInput.value);
                
                if(isNaN(amount) || amount <= 0) {
                    alert("Please enter a valid amount greater than zero");
                    return;
                }

                // Update savings display
                const savingsDisplay = document.querySelector('.bg-gradient-to-r.from-blue-50.to-indigo-50.p-6.rounded-xl.border.border-blue-100 h4');
                const currentSavings = parseFloat(savingsDisplay.textContent.replace('₱', '').replace(',', '')) || 0;
                const newSavings = currentSavings + amount;
                savingsDisplay.textContent = `₱${newSavings.toFixed(2)}`;
                
                // Update progress bar
                const progressBar = document.querySelector('.bg-gray-200.rounded-full.h-2.5 div');
                const progressPercentage = Math.min((newSavings / 5000) * 100, 100);
                progressBar.style.width = `${progressPercentage}%`;
                
                // Update percentage text
                const percentText = document.querySelector('.bg-gray-200.rounded-full.h-2.5 ~ div span:last-child');
                if(percentText) {
                    percentText.textContent = `${Math.round(progressPercentage)}%`;
                }
                
                // Update total balance and available funds
                const totalBalance = document.querySelector('.balance-animation');
                const availableFunds = document.querySelector('.text-xl.font-semibold.text-green-600');
                const currentBalance = parseFloat(totalBalance.textContent.replace('₱', '').replace(',', '')) || 0;
                const newBalance = currentBalance + amount;
                totalBalance.textContent = `₱${newBalance.toFixed(2)}`;
                availableFunds.textContent = `₱${newBalance.toFixed(2)}`;
                
                // Show success message
                alert(`Successfully added ₱${amount.toFixed(2)} to your savings!`);
                
                // Close modal
                savingsModal.classList.add('hidden');
            });

            // Deposit button functionality
            depositBtn.addEventListener('click', function() {
                depositModal.classList.remove('hidden');
                depositAmountInput.value = '';
            });

            // Close deposit modal
            closeDepositModal.addEventListener('click', function() {
                depositModal.classList.add('hidden');
            });
            
            cancelDeposit.addEventListener('click', function() {
                depositModal.classList.add('hidden');
            });

            // Confirm deposit
            confirmDeposit.addEventListener('click', function() {
                const amount = parseFloat(depositAmountInput.value);
                
                if(isNaN(amount) || amount <= 0) {
                    alert("Please enter a valid amount greater than zero");
                    return;
                }

                // Update balance displays
                const totalBalance = document.querySelector('.balance-animation');
                const availableFunds = document.querySelector('.text-xl.font-semibold.text-green-600');
                const currentBalance = parseFloat(totalBalance.textContent.replace('₱', '').replace(',', '')) || 0;
                const newBalance = currentBalance + amount;
                totalBalance.textContent = `₱${newBalance.toFixed(2)}`;
                availableFunds.textContent = `₱${newBalance.toFixed(2)}`;
                
                // Update savings display if needed
                const savingsDisplay = document.querySelector('.bg-gradient-to-r.from-blue-50.to-indigo-50.p-6.rounded-xl.border.border-blue-100 h4');
                const currentSavings = parseFloat(savingsDisplay.textContent.replace('₱', '').replace(',', '')) || 0;
                savingsDisplay.textContent = `₱${currentSavings.toFixed(2)}`;
                
                // Show success message
                alert(`Successfully deposited ₱${amount.toFixed(2)} to your account!`);
                
                // Close modal
                depositModal.classList.add('hidden');
            });

            // Transfer button functionality
            transferBtn.addEventListener('click', function() {
                transferModal.classList.remove('hidden');
                recipientAccountInput.value = '';
                transferAmountInput.value = '';
            });

            // Close transfer modal
            closeTransferModal.addEventListener('click', function() {
                transferModal.classList.add('hidden');
            });
            
            cancelTransfer.addEventListener('click', function() {
                transferModal.classList.add('hidden');
            });

            // Confirm transfer
            confirmTransfer.addEventListener('click', function() {
                const recipient = recipientAccountInput.value;
                const amount = parseFloat(transferAmountInput.value);
                
                if(!recipient) {
                    alert("Please enter recipient's account number");
                    return;
                }
                
                if(isNaN(amount) || amount <= 0) {
                    alert("Please enter a valid amount greater than zero");
                    return;
                }

                // Check if sufficient funds
                const totalBalance = document.querySelector('.balance-animation');
                const currentBalance = parseFloat(totalBalance.textContent.replace('₱', '').replace(',', '')) || 0;
                
                if(amount > currentBalance) {
                    alert("Insufficient funds for this transfer");
                    return;
                }

                // Update balance displays
                const newBalance = currentBalance - amount;
                totalBalance.textContent = `₱${newBalance.toFixed(2)}`;
                const availableFunds = document.querySelector('.text-xl.font-semibold.text-green-600');
                availableFunds.textContent = `₱${newBalance.toFixed(2)}`;
                
                // Show success message
                alert(`Successfully transferred ₱${amount.toFixed(2)} to account ${recipient.substring(0, 4)}...`);
                
                // Close modal
                transferModal.classList.add('hidden');
            });

            // Pay Bills button functionality
            payBillsBtn.addEventListener('click', function() {
                payBillsModal.classList.remove('hidden');
                billTypeInput.value = '';
                billAccountInput.value = '';
                billAmountInput.value = '';
            });

            // Close pay bills modal
            closePayBillsModal.addEventListener('click', function() {
                payBillsModal.classList.add('hidden');
            });
            
            cancelPayBills.addEventListener('click', function() {
                payBillsModal.classList.add('hidden');
            });

            // Confirm pay bills
            confirmPayBills.addEventListener('click', function() {
                const billType = billTypeInput.value;
                const accountNumber = billAccountInput.value;
                const amount = parseFloat(billAmountInput.value);
                
                if(!billType) {
                    alert("Please select a bill type");
                    return;
                }
                
                if(!accountNumber) {
                    alert("Please enter account number");
                    return;
                }
                
                if(isNaN(amount) || amount <= 0) {
                    alert("Please enter a valid amount greater than zero");
                    return;
                }

                // Update balance displays
                const totalBalance = document.querySelector('.balance-animation');
                const currentBalance = parseFloat(totalBalance.textContent.replace('₱', '').replace(',', '')) || 0;
                
                if(amount > currentBalance) {
                    alert("Insufficient funds to pay this bill");
                    return;
                }

                const newBalance = currentBalance - amount;
                totalBalance.textContent = `₱${newBalance.toFixed(2)}`;
                const availableFunds = document.querySelector('.text-xl.font-semibold.text-green-600');
                availableFunds.textContent = `₱${newBalance.toFixed(2)}`;
                
                // Show success message
                const billTypeName = billTypeInput.options[billTypeInput.selectedIndex].text;
                alert(`Successfully paid ₱${amount.toFixed(2)} for ${billTypeName} bill!`);
                
                // Close modal
                payBillsModal.classList.add('hidden');
            });

            // History button functionality
            historyBtn.addEventListener('click', function() {
                historyModal.classList.remove('hidden');
            });

            // Close history modal
            closeHistoryModal.addEventListener('click', function() {
                historyModal.classList.add('hidden');
            });

            // Print history
            printHistoryBtn.addEventListener('click', function() {
                window.print();
            });

            // Simulate some card interactions
            const cards = document.querySelectorAll('.card-hover');
            cards.forEach(card => {
                card.addEventListener('mouseenter', function() {
                    this.style.transform = 'translateY(-5px)';
                });
                card.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateY(0)';
                });
            });
        });
    </script>
</body>
</html>
